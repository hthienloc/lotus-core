--- a/src/core/log.cpp
+++ b/src/core/log.cpp
@@ -1,11 +1,16 @@
 /**
  * @file log.cpp
  * @brief Logging infrastructure for the Lotus Engine.
+ * @author Huỳnh Thiện Lộc
  */
 
 #include "lotus_engine/log.h"
 
+#include <chrono>
+#include <fstream>
 #include <mutex>
+#include <thread>
+#include <vector>
 
 namespace lotus_engine {
 
@@ -19,6 +24,49 @@ bool g_has_log_callback = false;
 static LogCallback g_log_callback = nullptr;
 static std::mutex g_log_mutex;
 
+// Tracing structures
+struct TraceEvent {
+    std::string name;
+    long long start_time_us;
+    long long duration_us;
+    std::thread::id thread_id;
+};
+
+#define MAX_TRACE_EVENTS 10000
+static std::vector<TraceEvent> g_trace_events;
+static std::mutex g_trace_mutex;
+
+// Helper to get time in microseconds
+static inline long long get_time_us() {
+    auto now = std::chrono::steady_clock::now();
+    return std::chrono::duration_cast<std::chrono::microseconds>(now.time_since_epoch()).count();
+}
+
+// ============================================================================
+// [ Tracing Scope ]
+// ============================================================================
+
+TraceScope::TraceScope(const std::string& name) : name(name), start_time(get_time_us()) {}
+
+TraceScope::~TraceScope() {
+    long long end_time = get_time_us();
+    long long duration = end_time - start_time;
+
+    {
+        std::lock_guard<std::mutex> lock(g_trace_mutex);
+        if (g_trace_events.size() >= MAX_TRACE_EVENTS) {
+            // Keep the vector size bounded by removing the oldest half
+            g_trace_events.erase(g_trace_events.begin(), g_trace_events.begin() + (MAX_TRACE_EVENTS / 2));
+        }
+        g_trace_events.push_back({name, start_time, duration, std::this_thread::get_id()});
+    }
+
+    // Also emit a log if DEBUG is enabled
+    if (g_has_log_callback && LogLevel::DEBUG >= g_max_log_level) {
+        emit_log(LogLevel::DEBUG, name, static_cast<double>(duration), "Scope completed");
+    }
+}
+
 // ============================================================================
 // [ Logging Implementation ]
 // ============================================================================
@@ -44,16 +92,58 @@ void set_max_log_level(LogLevel level) {
 /**
  * @brief Emits a log message to the registered callback.
  * @param level The severity level of the log.
+ * @param stage The pipeline stage name.
+ * @param time_us The execution time in microseconds.
  * @param message The log message content.
  */
-void emit_log(LogLevel level, const std::string& message) {
+void emit_log(LogLevel level, const std::string& stage, double time_us, const std::string& message) {
     if (!g_has_log_callback || level < g_max_log_level) {
         return;
     }
     std::lock_guard<std::mutex> lock(g_log_mutex);
     if (g_log_callback) {
-        g_log_callback(level, message);
+        g_log_callback(level, stage, time_us, message);
+    }
+}
+
+/**
+ * @brief Export tracing data to a JSON file.
+ * @param filepath The path to the file to export to.
+ */
+void export_tracing(const std::string& filepath) {
+    std::lock_guard<std::mutex> lock(g_trace_mutex);
+
+    std::ofstream out(filepath);
+    if (!out.is_open()) {
+        return;
+    }
+
+    out << "{\"traceEvents\":[\n";
+    bool first = true;
+    for (const auto& event : g_trace_events) {
+        if (!first) {
+            out << ",\n";
+        }
+        first = false;
+
+        // Convert thread ID to a stable number for tracing tools
+        size_t tid = std::hash<std::thread::id>{}(event.thread_id);
+
+        out << "  {\n"
+            << "    \"name\": \"" << event.name << "\",\n"
+            << "    \"cat\": \"lotus_engine\",\n"
+            << "    \"ph\": \"X\",\n"
+            << "    \"ts\": " << event.start_time_us << ",\n"
+            << "    \"dur\": " << event.duration_us << ",\n"
+            << "    \"pid\": 1,\n"
+            << "    \"tid\": " << tid << "\n"
+            << "  }";
     }
+    out << "\n]}\n";
+    out.close();
+    
+    // Clear events after export
+    g_trace_events.clear();
 }
 
 }  // namespace lotus_engine
