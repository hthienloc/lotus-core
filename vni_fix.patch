+++ b/src/core/engine.cpp
@@ -796,46 +796,187 @@ void Engine::apply_telex_modifiers(std::string& current_str, char32_t key, bool&
  */
 void Engine::apply_vni_modifiers(std::string& current_str, char32_t key, bool& key_consumed,
                                  Tone& tone_state) {
-    const std::string raw_str = unicode::to_utf8(buffer);
+    std::u32string u32 = unicode::to_utf32(current_str);
+    std::string raw_str = unicode::to_utf8(u32);
+    
     if (Linguistics::is_definite_english(raw_str))
         return;
 
-    bool has_mod = false;
-    char32_t lk = unicode::to_lower(key);
+    // Filter out all keys that are not 0-9
+    if (key < '0' || key > '9') return;
+    
+    // We only want to process the CURRENT key pressed. The engine buffer
+    // only has the un-processed modifiers left in it anyway if they weren't matched.
+    // Wait, the entire buffer might have multiple modifiers. E.g. "a11" -> '1' typed twice.
+    // Or "a61" -> 'a', '6', '1'.
+    // Let's rely on standard engine behavior where modifiers are passed through the keys.
+    // Wait! The `current_str` ALREADY HAS the numbers in it because it's derived from `buffer` in `process_key`.
+    
+    // Stage 1: Indexing & Reversion
+    std::vector<size_t> digit_indices;
+    std::vector<bool> to_strip(u32.size(), false);
+    std::vector<bool> is_literal(u32.size(), false);
+    
+    for (size_t i = 0; i < u32.size(); ++i) {
+        if (u32[i] >= U'0' && u32[i] <= U'9') {
+            digit_indices.push_back(i);
+        }
+    }
+
+    // Pass 1: Identify escape pairs (e.g., a11 -> a1, a66 -> a6)
+    for (size_t i = 0; i < digit_indices.size(); ++i) {
+        size_t idx = digit_indices[i];
+        if (i + 1 < digit_indices.size() && u32[idx] == u32[digit_indices[i + 1]]) {
+            is_literal[idx] = true;
+            to_strip[digit_indices[i + 1]] = true;
+            i++;
+        }
+    }
+
+    // Stage 2: Linguistic Gating
+    std::vector<size_t> valid_digit_indices;
+    for(size_t idx : digit_indices) {
+        if (!is_literal[idx] && !to_strip[idx]) {
+            // Apply linguistic gate for tones
+            char32_t k = u32[idx];
+            if ((k >= U'1' && k <= U'5') || k == U'0') {
+                 std::u32string base_u32;
+                 for (size_t j = 0; j < idx; ++j) {
+                     if (!to_strip[j] &&
+                         (is_literal[j] || std::find(digit_indices.begin(), digit_indices.end(), j) == digit_indices.end())) {
+                         base_u32 += u32[j]; // Use original u32 since we just want to see if vowels exist
+                     }
+                 }
+                 bool has_vowel = false;
+                 for (char32_t cp : base_u32) {
+                     if (SyllableParser::is_vowel(cp)) {
+                         has_vowel = true;
+                         break;
+                     }
+                 }
+                 if (has_vowel) {
+                     valid_digit_indices.push_back(idx);
+                 }
+            } else {
+                 valid_digit_indices.push_back(idx);
+            }
+        }
+    }
+    
+    // Stage 3: Modifiers Application
+    std::u32string u32_copy = u32;
 
-    for (size_t i = 0; i < raw_str.length(); ++i) {
-        char k = raw_str[i];
-        if (k < '0' || k > '9')
-            continue;
+    // Apply phases over valid digits
+    for(size_t phase = 1; phase <= 3; ++phase) {
+        for (size_t idx : valid_digit_indices) {
+            char32_t k = u32[idx];
+            bool applied = false;
+            
+            if (phase == 1) {
+                 if (k == U'7') {
+                     size_t actual_u = std::u32string::npos;
+                     size_t actual_o = std::u32string::npos;
+                     size_t actual_a = std::u32string::npos;
+                     
+                     for(int i=(int)u32_copy.size()-1; i>=0; --i) {
+                          if(!to_strip[i] || (size_t)i == idx) {
+                               if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'o' && actual_o == std::u32string::npos) actual_o = i;
+                               if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'u' && actual_u == std::u32string::npos) actual_u = i;
+                               if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'a' && actual_a == std::u32string::npos) actual_a = i;
+                          }
+                     }
+                     
+                     // Force apply to earlier matching chars, ignoring proximity limits since VNI allows distant modifiers
+                     if (actual_u != std::u32string::npos && actual_o != std::u32string::npos) {
+                         bool is_lower_u = unicode::to_lower(u32_copy[actual_u]) == u32_copy[actual_u];
+                         bool is_lower_o = unicode::to_lower(u32_copy[actual_o]) == u32_copy[actual_o];
+                         u32_copy[actual_u] = unicode::transfer_tone(is_lower_u ? U'ư' : U'Ư', u32_copy[actual_u]);
+                         u32_copy[actual_o] = unicode::transfer_tone(is_lower_o ? U'ơ' : U'Ơ', u32_copy[actual_o]);
+                         applied = true;
+                     } else if (actual_u != std::u32string::npos && actual_a != std::u32string::npos) {
+                         bool is_lower_u = unicode::to_lower(u32_copy[actual_u]) == u32_copy[actual_u];
+                         u32_copy[actual_u] = unicode::transfer_tone(is_lower_u ? U'ư' : U'Ư', u32_copy[actual_u]);
+                         applied = true;
+                     } else {
+                         if (actual_u != std::u32string::npos) {
+                             bool is_lower_u = unicode::to_lower(u32_copy[actual_u]) == u32_copy[actual_u];
+                             u32_copy[actual_u] = unicode::transfer_tone(is_lower_u ? U'ư' : U'Ư', u32_copy[actual_u]);
+                             applied = true;
+                         }
+                         if (actual_o != std::u32string::npos) {
+                             bool is_lower_o = unicode::to_lower(u32_copy[actual_o]) == u32_copy[actual_o];
+                             u32_copy[actual_o] = unicode::transfer_tone(is_lower_o ? U'ơ' : U'Ơ', u32_copy[actual_o]);
+                             applied = true;
+                         }
+                     }
+                 } else if (k == U'8') {
+                     for(int i=(int)u32_copy.size()-1; i>=0; --i) {
+                         if (!to_strip[i] || (size_t)i == idx) {
+                             if (u32_copy[i] == U'a') { u32_copy[i] = U'ă'; applied = true; break; }
+                             if (u32_copy[i] == U'A') { u32_copy[i] = U'Ă'; applied = true; break; }
+                         }
+                     }
+                 } else if (k == U'9') {
+                     for(int i=(int)u32_copy.size()-1; i>=0; --i) {
+                         if (!to_strip[i] || (size_t)i == idx) {
+                             if (u32_copy[i] == U'd') { u32_copy[i] = U'đ'; applied = true; break; }
+                             if (u32_copy[i] == U'D') { u32_copy[i] = U'Đ'; applied = true; break; }
