@@ -0,0 +1,18 @@
+#include <iostream>
+#include <string>
+#include "lotus_engine/engine.h"
+
+int main() {
+    lotus_engine::Engine engine;
+    engine.set_method(lotus_engine::InputMethod::VNI);
+    std::string keys = "duong795";
+    lotus_engine::Modifiers mods;
+    std::string current_buffer;
+    for(char c : keys) {
+        auto res = engine.process_key(c, mods);
