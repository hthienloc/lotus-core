+-                               if ((unicode::to_lower(u32_copy[i]) == U'o' || unicode::to_lower(u32_copy[i]) == U'ô' || unicode::to_lower(u32_copy[i]) == U'ơ') && actual_o == std::u32string::npos) actual_o = i;
