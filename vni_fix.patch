+    assert_typing_vni(engine, "a1", "á");
+    assert_typing_vni(engine, "a11", "a1");
+    assert_typing_vni(engine, "a12", "à");
+    assert_typing_vni(engine, "a6", "â");
+    assert_typing_vni(engine, "a66", "a6");
+
+    std::cout << "  [PASS] VNI marker reversion logic" << std::endl;
+}
