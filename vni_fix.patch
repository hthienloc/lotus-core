+/**
+ * @brief Tests VNI floating tone and vowel markers (markers typed at the end of the word).
+ */
+void test_engine_vni_floating() {
+    Engine engine;
+    // Tone markers at the end
+    assert_typing_vni(engine, "duong5", "dụng"); 
+    assert_typing_vni(engine, "hoang2", "hoàng");
+    
+    // Vowel markers late
+    assert_typing_vni(engine, "duong7", "dương");
+    assert_typing_vni(engine, "viec6", "việc");
+
+    // Both vowel and tone late
+    assert_typing_vni(engine, "duong75", "dượng");
+    assert_typing_vni(engine, "duong795", "đượng"); // d -> đ, uo -> ươ, tone -> nặng
+
+    std::cout << "  [PASS] VNI floating markers" << std::endl;
+}
+
+/**
