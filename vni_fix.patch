diff --git a/run_single_test.cpp b/run_single_test.cpp
new file mode 100644
index 0000000..f35bfd8
--- /dev/null
+++ b/run_single_test.cpp
@@ -0,0 +1,33 @@
+#include "lotus_engine/engine.h"
+#include "lotus_engine/unicode.h"
+#include <iostream>
+
+void assert_typing_vni(lotus_engine::Engine& engine, const std::string& keys, const std::string& expected) {
+    engine.reset();
+    lotus_engine::Modifiers mods;
+    std::vector<char32_t> output;
+
+    for (char c : keys) {
+        lotus_engine::EngineResult res = engine.process_key((char32_t)c, mods);
+        for (int i = 0; i < res.backspace; ++i) {
+            if (!output.empty()) {
+                output.pop_back();
+            }
+        }
+        for (int i = 0; i < res.count; ++i) {
+            output.push_back(res.chars[i]);
+        }
+    }
+    std::string actual_utf8 = lotus_engine::unicode::to_utf8(std::u32string(output.begin(), output.end()));
+    std::cout << "Input: " << keys << " -> Output: " << actual_utf8 << " (Expected: " << expected << ")" << std::endl;
+}
+
+int main() {
+    lotus_engine::Engine engine;
+    engine.set_method(lotus_engine::InputMethod::VNI);
+    assert_typing_vni(engine, "duong7", "đương");
+    assert_typing_vni(engine, "duong79", "đương");
+    assert_typing_vni(engine, "duong795", "đượng");
+    assert_typing_vni(engine, "a61", "ấ");
+    return 0;
+}
diff --git a/src/core/engine.cpp b/src/core/engine.cpp
