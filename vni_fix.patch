+-                         u32_copy[actual_u] = (u32_copy[actual_u] == U'u' || u32_copy[actual_u] == U'ư') ? U'ư' : U'Ư';
++                         u32_copy[actual_u] = (u32_copy[actual_u] == U'u' || u32_copy[actual_u] == U'ư' || u32_copy[actual_u] == U'ủ' || u32_copy[actual_u] == U'ù' || u32_copy[actual_u] == U'ú' || u32_copy[actual_u] == U'ụ' || u32_copy[actual_u] == U'ũ') ? U'ư' : U'Ư';
