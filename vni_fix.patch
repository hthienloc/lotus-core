+@@ -923,12 +923,12 @@
+                  if (k == U'6') {
+                      for(int i=(int)u32_copy.size()-1; i>=0; --i) {
+                          if (!to_strip[i] || (size_t)i == idx) {
+-                             if (u32_copy[i] == U'a') { u32_copy[i] = U'â'; applied = true; break; }
+-                             if (u32_copy[i] == U'A') { u32_copy[i] = U'Â'; applied = true; break; }
+-                             if (u32_copy[i] == U'e') { u32_copy[i] = U'ê'; applied = true; break; }
+-                             if (u32_copy[i] == U'E') { u32_copy[i] = U'Ê'; applied = true; break; }
+-                             if (u32_copy[i] == U'o') { u32_copy[i] = U'ô'; applied = true; break; }
+-                             if (u32_copy[i] == U'O') { u32_copy[i] = U'Ô'; applied = true; break; }
++                             if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'a') { u32_copy[i] = (unicode::to_lower(u32_copy[i]) == u32_copy[i]) ? U'â' : U'Â'; applied = true; break; }
++                             if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'e') { u32_copy[i] = (unicode::to_lower(u32_copy[i]) == u32_copy[i]) ? U'ê' : U'Ê'; applied = true; break; }
++                             if (unicode::strip_tone(unicode::to_lower(u32_copy[i])) == U'o') { u32_copy[i] = (unicode::to_lower(u32_copy[i]) == u32_copy[i]) ? U'ô' : U'Ô'; applied = true; break; }
+                          }
+                      }
+                  }
