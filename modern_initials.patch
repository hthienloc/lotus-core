+/**
+ * @brief Tests enabling modern initials (z, w, j, f) in the engine.
+ */
+void test_engine_modern_initials() {
+    Engine engine;
+    engine.set_auto_restore(true);
+    engine.set_method(InputMethod::TELEX); // Use TELEX
+
+    // By default, modern initials should be rejected as invalid initials and stay raw
+    assert_typing(engine, "za1", "za1");
+    assert_typing(engine, "wa1", "wa1");
+    assert_typing(engine, "ja1", "ja1");
+    assert_typing(engine, "fa1", "fa1");
+    
+    // Test telex mapping just to be sure we are isolating modern initial behavior
+    assert_typing(engine, "zas", "zas");
+    assert_typing(engine, "was", "was");
+    assert_typing(engine, "jas", "jas");
+    assert_typing(engine, "fas", "fas");
+
+    // Enable modern initials
+    engine.set_allow_modern_initials(true);
+
+    // Now, they should be treated as valid Vietnamese initials, allowing tone processing
+    // VNI
+    engine.set_method(InputMethod::VNI);
+    assert_typing(engine, "za1", "zá");
+    assert_typing(engine, "wa1", "wá");
+    assert_typing(engine, "ja1", "já");
+    assert_typing(engine, "fa1", "fá");
+
+    // TELEX
+    engine.set_method(InputMethod::TELEX);
+    // Note: In TELEX, 'w' might have special logic due to `free_w`, but it still works for simple cases.
+    // 'w' is also a hook marker (ư) so typing 'was' could be wás or ưas depending on logic. Let's just stick to tones.
+    assert_typing(engine, "zas", "zá");
+    assert_typing(engine, "jas", "já");
+    assert_typing(engine, "fas", "fá");
+
+    std::cout << "  [PASS] Modern Initials (z, w, j, f)" << std::endl;
+}
