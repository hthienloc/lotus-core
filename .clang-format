---
Language: Cpp
# Thụt lề 4 dấu cách
IndentWidth: 4
TabWidth: 4
UseTab: Never

# Giới hạn độ dài dòng
ColumnLimit: 100

# Vị trí dấu ngoặc nhọn (Attach kiểu K&R/Google)
BreakBeforeBraces: Attach

# Sắp xếp Include
SortIncludes: true
IncludeBlocks: Preserve

# Không tự động xóa các dòng trắng do người dùng chủ đích
MaxEmptyLinesToKeep: 2

# Giữ nguyên các định dạng của khối comment lớn
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignTrailingComments: true

# Cho phép gộp các hàm ngắn vào 1 dòng để code gọn hơn
AllowShortFunctionsOnASingleLine: All
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: WithoutElse

# C++ 20 Standard
Standard: Latest

# Bảo tồn định dạng của danh sách khởi tạo
ConstructorInitializerIndentWidth: 4
PackConstructorInitializers: BinPack
...
